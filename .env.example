VITE_API_URL=http://localhost:5000/api/v1
VITE_REALTIME_URL=

NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/scaleops
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173
VERCEL_PREVIEW_ORIGINS_ENABLED=false

JWT_SECRET=replace_with_strong_jwt_secret
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=proofarena_refresh

CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret
CLOUDINARY_FOLDER=scaleops

EMAIL_ENABLED=false
STRIPE_BILLING_ENABLED=false
STRIPE_MARKETPLACE_ENABLED=false
QUEUE_DRIVER=memory
